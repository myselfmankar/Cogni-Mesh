# Environment Configuration
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# 2026 Upgrades (Optional but Recommended)
COHERE_API_KEY=YOUR_COHERE_API_KEY_HERE  # Get free at cohere.com
USE_RERANKING=true
USE_HYBRID_SEARCH=true
USE_NEO4J=false  # Set to true if you have Neo4j running

# Neo4j Settings (Optional - only needed if USE_NEO4J=true)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

# Vector Database
CHROMA_DB_DIR=./chroma_db
COLLECTION_NAME=cogni_mesh_vectors
